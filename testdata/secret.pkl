//
// Conformance test — create SUPABASE::Functions::Secrets.

amends "@formae/forma.pkl"
import "@supabase/supabase.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new supabase.Secrets {
    label = "plugin-sdk-test-secret"
    projectRef = v.supabaseProjectRef
    // Names starting with SUPABASE_ are rejected by the API.
    values {
      ["SDK_TEST_\(v.testRunID)"] = "sdk-test-value-\(v.testRunID)"
    }
  }
}
