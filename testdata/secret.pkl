//
// Conformance test — create SUPABASE::Functions::Secret.

amends "@formae/forma.pkl"
import "@supabase/supabase.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new supabase.Secret {
    label = "plugin-sdk-test-secret"
    projectRef = v.supabaseProjectRef
    // Names starting with SUPABASE_ are rejected by the API.
    name = "SDK_TEST_\(v.testRunID)"
    value = "sdk-test-value-\(v.testRunID)"
  }
}
