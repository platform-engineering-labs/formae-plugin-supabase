import "@formae/formae.pkl"
import "@supabase/supabase.pkl"

// Test run id stamps unique names per run so parallel/repeat runs don't collide.
testRunID = read("env:FORMAE_TEST_RUN_ID")

// Common stack used by every conformance test.
stackName = "plugin-sdk-test-supabase-\(testRunID)"

// Stack object the tests reuse.
stack = new formae.Stack {
    label = stackName
    description = "Plugin SDK conformance test for SUPABASE"
}

// Organization that owns test projects. Required for Project create.
organizationID = read("env:SUPABASE_ORGANIZATION_ID")

// Existing project ref used by every sub-resource (Branch, APIKey, EdgeFunction,
// Secret, *Settings). Lets the tests run fast without paying for full project
// provisioning each cycle.
supabaseProjectRef = read("env:SUPABASE_PROJECT_REF")

// AWS region the test resources live in. us-east-1 is the safest default.
region = read?("env:SUPABASE_REGION") ?? "us-east-1"

// Postgres password for the Project create test. >= 8 chars.
dbPass = read?("env:SUPABASE_DB_PASS") ?? "plugin-sdk-test-pass-\(testRunID)"

// Shared target. `projectRef` scopes List() to the one project the test
// suite shares — keeps discovery within the conformance harness's
// 2-minute timeout window regardless of how many projects the PAT can see.
target = new formae.Target {
    label = "supabase-target"
    config = new supabase.Config {
        projectRef = supabaseProjectRef
    }
}
