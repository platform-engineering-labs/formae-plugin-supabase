// Conformance test — update SUPABASE::Database::PoolerConfig.

amends "@formae/forma.pkl"
import "@supabase/supabase.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new supabase.PoolerConfig {
    label = "plugin-sdk-test-pooler-config"
    projectRef = v.supabaseProjectRef
    settings = new Mapping {
      ["pool_mode"]         = "session"    // CHANGED
      ["default_pool_size"] = 25           // CHANGED
    }
  }
}
