// Conformance test — update SUPABASE::Platform::Branch.
// Flips `persistent` and renames `branch_name`. Parent ref + region are createOnly.

amends "@formae/forma.pkl"
import "@supabase/supabase.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new supabase.Branch {
    label = "plugin-sdk-test-branch"
    parentProjectRef = v.supabaseProjectRef
    branch_name = "sdk-test-\(v.testRunID)-renamed"   // CHANGED
    persistent = true                                  // CHANGED
  }
}
