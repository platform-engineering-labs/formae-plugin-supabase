// Conformance test — update SUPABASE::Config::APISettings.

amends "@formae/forma.pkl"
import "@supabase/supabase.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new supabase.APISettings {
    label = "plugin-sdk-test-api-settings"
    projectRef = v.supabaseProjectRef
    settings = new Mapping {
      ["db_schema"] = "public"
      ["max_rows"] = 2000                                // CHANGED
    }
  }
}
