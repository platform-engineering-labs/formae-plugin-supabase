//
// Conformance test — rotate SUPABASE::Functions::Secret value.
// Name is createOnly; value mutation re-POSTs to the bulk endpoint.

amends "@formae/forma.pkl"
import "@supabase/supabase.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new supabase.Secret {
    label = "plugin-sdk-test-secret"
    projectRef = v.projectRef
    name = "SDK_TEST_\(v.testRunID)"
    value = "sdk-test-value-\(v.testRunID)-ROTATED"      // CHANGED
  }
}
