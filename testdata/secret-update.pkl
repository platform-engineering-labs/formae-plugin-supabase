//
// Conformance test — rotate a value in SUPABASE::Functions::Secrets.
// projectRef is createOnly; value mutation re-POSTs to the bulk endpoint.

amends "@formae/forma.pkl"
import "@supabase/supabase.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new supabase.Secrets {
    label = "plugin-sdk-test-secret"
    projectRef = v.supabaseProjectRef
    values {
      ["SDK_TEST_\(v.testRunID)"] = "sdk-test-value-\(v.testRunID)-ROTATED"   // CHANGED
    }
  }
}
