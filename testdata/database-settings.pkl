//
// Conformance test — apply SUPABASE::Config::DatabaseSettings to an existing
// project. Note: this endpoint uses PUT (not PATCH); the singleton helper
// dispatches the right method.

amends "@formae/forma.pkl"
import "@supabase/supabase.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new supabase.DatabaseSettings {
    label = "plugin-sdk-test-database-settings"
    projectRef = v.supabaseProjectRef
    settings = new Mapping {
      ["statement_timeout"] = "8s"
    }
  }
}
