// Conformance test — update SUPABASE::Config::AuthSettings.

amends "@formae/forma.pkl"
import "@supabase/supabase.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new supabase.AuthSettings {
    label = "plugin-sdk-test-auth-settings"
    projectRef = v.supabaseProjectRef
    settings = new Mapping {
      ["site_url"] = "https://sdk-test-\(v.testRunID)-updated.example"   // CHANGED
      ["mailer_autoconfirm"] = false                                      // CHANGED
    }
  }
}
