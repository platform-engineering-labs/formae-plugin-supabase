//
// Conformance test — create SUPABASE::Auth::APIKey on an existing project.

amends "@formae/forma.pkl"
import "@supabase/supabase.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new supabase.APIKey {
    label = "plugin-sdk-test-apikey"
    projectRef = v.supabaseProjectRef
    apikey_type = "secret"
    // Name pattern: lowercase, [a-z_][a-z0-9_]+, 4–64 chars.
    name = "sdk_test_\(v.testRunID)"
    description = "Plugin SDK conformance test key"
  }
}
