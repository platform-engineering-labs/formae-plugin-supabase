//
// Conformance test — apply SUPABASE::Database::PoolerConfig.
// Mutable knobs: default_pool_size (0..3000), pool_mode (transaction|session).

amends "@formae/forma.pkl"
import "@supabase/supabase.pkl"

import "./config/vars.pkl" as v

forma {
  v.stack
  v.target

  new supabase.PoolerConfig {
    label = "plugin-sdk-test-pooler-config"
    projectRef = v.supabaseProjectRef
    settings = new Mapping {
      ["pool_mode"]         = "transaction"
      ["default_pool_size"] = 15
    }
  }
}
