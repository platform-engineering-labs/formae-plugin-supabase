# Single-command demo runner. Uses formae for everything formae can manage
# (Supabase resources, k8s resources) and wraps the un-managed container
# build / image load steps so you never have to think about them.
#
# Usage:
#   cp ../../.env .env                # or symlink — must define SUPABASE_*
#   make demo                         # full end-to-end (build, load, apply)
#   make demo-prepare                 # everything EXCEPT the apply (for live demos)
#     source .demo.env                # pulls env vars into your shell
#     formae apply --mode reconcile --yes forma.pkl
#   make port-forward                 # open localhost:8081
#   make destroy                      # tear down

KIND_CLUSTER ?= formae-test
IMAGE        ?= k8s-supabase-demo:latest
NAMESPACE    ?= supabase-demo

# Read SUPABASE_* + DEMO_IMAGE from the repo-root .env if present.
ENV_FILE := ../../.env
ifneq (,$(wildcard $(ENV_FILE)))
include $(ENV_FILE)
export
endif

.PHONY: demo demo-prepare image load apply agent-restart port-forward destroy clean

## demo: end-to-end — build, load, apply, then print the local URL
demo: image load apply
	@echo ""
	@echo "Demo running. Next:"
	@echo "  make port-forward   # then open http://localhost:8081"
	@echo "  make destroy        # tear down"

## demo-prepare: everything EXCEPT the apply. Writes .demo.env for sourcing.
## Use this before a live demo so the only thing the audience sees is
## `formae apply forma.pkl`.
demo-prepare: image load agent-restart
	@test -n "$$SUPABASE_ACCESS_TOKEN"    || (echo "SUPABASE_ACCESS_TOKEN unset"; exit 1)
	@test -n "$$SUPABASE_ORGANIZATION_ID" || (echo "SUPABASE_ORGANIZATION_ID unset"; exit 1)
	@test -n "$$SUPABASE_PROJECT_REF"     || (echo "SUPABASE_PROJECT_REF unset"; exit 1)
	@echo "Resolving publishable key from $$SUPABASE_PROJECT_REF…"
	@key=$$(curl -fsS -H "Authorization: Bearer $$SUPABASE_ACCESS_TOKEN" \
	    "https://api.supabase.com/v1/projects/$$SUPABASE_PROJECT_REF/api-keys?reveal=true" \
	    | jq -r '[.[] | select(.type == "publishable")][0].api_key // empty'); \
	  if [ -z "$$key" ]; then \
	    echo "  no publishable key on project yet — the first apply will mint one."; \
	    key="PLACEHOLDER_KEY_WILL_BE_CREATED_BY_FIRST_APPLY"; \
	  fi; \
	  ( \
	    echo "# Generated by 'make demo-prepare'. Source me, then run formae apply."; \
	    echo "export SUPABASE_ACCESS_TOKEN='$$SUPABASE_ACCESS_TOKEN'"; \
	    echo "export SUPABASE_ORGANIZATION_ID='$$SUPABASE_ORGANIZATION_ID'"; \
	    echo "export SUPABASE_PROJECT_REF='$$SUPABASE_PROJECT_REF'"; \
	    echo "export SUPABASE_REGION='$${SUPABASE_REGION:-eu-west-3}'"; \
	    echo "export SUPABASE_ANON_KEY='$$key'"; \
	    echo "export DEMO_IMAGE='$(IMAGE)'"; \
	    echo "export INGRESS_HOST='$${INGRESS_HOST:-supabase-demo.local}'"; \
	  ) > .demo.env
	@echo ""
	@echo "Ready. Run:"
	@echo "    source .demo.env"
	@echo "    formae apply --mode reconcile --yes forma.pkl"
	@echo "    make port-forward    # then open http://localhost:8081"

## agent-restart: stop + start the formae agent so it picks up the .env vars
agent-restart:
	@echo "Restarting formae agent with current env…"
	-@formae agent stop >/dev/null 2>&1 || true
	@sleep 4
	@nohup formae agent start > /tmp/agent.log 2>&1 &
	@sleep 4
	@ps -ef | grep "formae agent start" | grep -v grep >/dev/null \
	    || (echo "agent failed to start — see /tmp/agent.log"; exit 1)
	@echo "agent ready (pid=$$(pgrep -f 'formae agent start'))"

## image: build the Next.js + Supabase demo container locally
image:
	docker build -t $(IMAGE) .

## load: load the image into the local kind cluster (skip when using a remote registry)
load:
	kind load docker-image $(IMAGE) --name $(KIND_CLUSTER)

## apply: provision Supabase + k8s resources via formae
apply:
	@test -n "$$SUPABASE_ACCESS_TOKEN"   || (echo "SUPABASE_ACCESS_TOKEN unset"; exit 1)
	@test -n "$$SUPABASE_ORGANIZATION_ID" || (echo "SUPABASE_ORGANIZATION_ID unset"; exit 1)
	@test -n "$$SUPABASE_PROJECT_REF"     || (echo "SUPABASE_PROJECT_REF unset"; exit 1)
	@# Fetch a publishable key (creates one via formae if not yet present).
	@key=$$(curl -fsS -H "Authorization: Bearer $$SUPABASE_ACCESS_TOKEN" \
	    "https://api.supabase.com/v1/projects/$$SUPABASE_PROJECT_REF/api-keys?reveal=true" \
	    | jq -r '[.[] | select(.type == "publishable")][0].api_key // empty'); \
	  DEMO_IMAGE=$(IMAGE) \
	  SUPABASE_ANON_KEY=$$key \
	  formae apply --mode reconcile --yes forma.pkl

## port-forward: open localhost:8081 to the in-cluster service
port-forward:
	@echo "Open http://localhost:8081  (Ctrl-C to stop)"
	kubectl -n $(NAMESPACE) port-forward svc/supabase-demo 8081:80

## destroy: tear down via formae + revoke Supabase key
destroy:
	-formae destroy --yes forma.pkl

## clean: remove built artifacts (image stays in docker / kind)
clean:
	rm -rf app/node_modules app/.next PklProject.deps.json .demo.env
