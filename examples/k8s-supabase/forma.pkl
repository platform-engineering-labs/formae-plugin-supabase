//
// k8s <> Supabase cross-plugin demo.
//
// What it does:
//   1. Mints a publishable API key on an existing Supabase project
//      (SUPABASE::Auth::APIKey).
//   2. Patches the project's Auth site_url so login redirects land on the
//      k8s ingress (SUPABASE::Config::AuthSettings).
//   3. Stamps a k8s Secret with NEXT_PUBLIC_SUPABASE_URL and
//      NEXT_PUBLIC_SUPABASE_ANON_KEY, sourced from the Supabase resources.
//   4. Runs a Deployment + Service + Ingress in k8s that reads the secret
//      and proves the wiring by calling the Supabase Auth /settings
//      endpoint at request time.
//
// Setup before applying:
//   export SUPABASE_ACCESS_TOKEN=sbp_xxx
//   export SUPABASE_ORGANIZATION_ID=...
//   export SUPABASE_PROJECT_REF=...
//   export DEMO_IMAGE=ghcr.io/your-org/k8s-supabase-demo:latest  # built from ./Dockerfile
//   export INGRESS_HOST=supabase-demo.local
//
// Apply:
//   formae apply --mode reconcile --watch forma.pkl

amends "@formae/forma.pkl"

import "@formae/formae.pkl"
import "@supabase/supabase.pkl"

import "@k8s/k8s.pkl"
import "@k8s/core/Namespace.pkl" as ns
import "@k8s/core/Secret.pkl" as secret
import "@k8s/core/Service.pkl" as svc
import "@k8s/apps/Deployment.pkl" as dep
import "@k8s/networking/Ingress.pkl" as ing

local supabaseOrg     = read("env:SUPABASE_ORGANIZATION_ID")
local supabaseProject = read("env:SUPABASE_PROJECT_REF")
local demoImage       = read("env:DEMO_IMAGE")
local ingressHost     = read?("env:INGRESS_HOST") ?? "supabase-demo.local"

// Anon key threaded in from env. Two-phase apply:
//   1) formae apply phase 1 → creates the supabase.APIKey resource
//   2) export SUPABASE_ANON_KEY=$(<live key from previous apply>)
//   3) formae apply phase 2 → seeds the k8s Secret with that value
//
// The supabase plugin emits anonKey.res.apiKey for same-plugin DAG. The
// k8s plugin's Secret.stringData is typed as Mapping<String,String> and
// does not (yet) accept cross-plugin Resolvable, so the env shim stays.
local supabaseAnonKey = read?("env:SUPABASE_ANON_KEY") ?? ""

local appName  = "supabase-demo"
local appLabel = "supabase-demo"
local nsName   = "supabase-demo"

local appLabels = new Mapping<String, String> {
    ["app"] = appLabel
}

forma {

    new formae.Stack {
        label = "k8s-supabase-demo"
        description = "Cross-plugin demo: k8s app reading Supabase credentials"
    }

    // -- Targets ---------------------------------------------------------------

    local supabaseTarget = new formae.Target {
        label = "supabase-target"
        config = new supabase.Config {
            organizationId = supabaseOrg
        }
    }
    supabaseTarget

    local k8sTarget = new formae.Target {
        label = "supabase-demo-k8s"
        // Uses ~/.kube/config (default context). Swap to k8s.EKSAuth /
        // k8s.GKEAuth / k8s.AKSAuth / k8s.OVHAuth / k8s.OCIAuth for cloud
        // clusters — see the k8s plugin docs for cluster-specific options.
        config = new k8s.Config {
            kubernetesVersion = "1.32"
            auth = new k8s.KubeconfigAuth {}
        }
    }
    k8sTarget

    // -- Supabase side ---------------------------------------------------------

    local anonKey = new supabase.APIKey {
        label = "demo-publishable"
        target = supabaseTarget.res
        projectRef = supabaseProject
        apikey_type = "publishable"
        name = "k8s_demo_publishable"
        description = "k8s_supabase_demo"
    }
    anonKey

    new supabase.AuthSettings {
        label = "demo-auth-settings"
        target = supabaseTarget.res
        projectRef = supabaseProject
        settings = new Mapping {
            ["site_url"] = "http://\(ingressHost)"
        }
    }

    // -- K8s side --------------------------------------------------------------

    new ns.Namespace {
        label = "demo-namespace"
        target = k8sTarget.res
        metadata {
            name = nsName
            labels { ["managed-by"] = "formae" }
        }
    }

    new secret.Secret {
        label = "demo-supabase-creds"
        target = k8sTarget.res
        metadata {
            name = "supabase-creds"
            namespace = nsName
        }
        type = "Opaque"
        stringData {
            ["NEXT_PUBLIC_SUPABASE_URL"]             = "https://\(supabaseProject).supabase.co"
            // Cross-plugin DAG would let formae resolve `anonKey.res.apiKey`
            // at apply time, but k8s Secret.stringData is `Mapping<String,
            // String>` (strict) so we thread the value via env for now.
            ["NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY"] = supabaseAnonKey
        }
    }

    new dep.Deployment {
        label = "demo-deployment"
        target = k8sTarget.res
        metadata {
            name = appName
            namespace = nsName
            labels = appLabels
        }
        spec {
            replicas = 1
            selector { matchLabels = appLabels }
            template {
                metadata {
                    name = appName
                    labels = appLabels
                }
                spec {
                    containers {
                        new {
                            name = "demo"
                            image = demoImage
                            imagePullPolicy = "IfNotPresent"
                            ports { new { containerPort = 8080 } }
                            envFrom { new {
                                secretRef { name = "supabase-creds" }
                            } }
                        }
                    }
                }
            }
        }
    }

    new svc.Service {
        label = "demo-service"
        target = k8sTarget.res
        metadata {
            name = appName
            namespace = nsName
        }
        spec {
            selector = appLabels
            ports { new { port = 80; targetPort = 8080 } }
        }
    }

    new ing.Ingress {
        label = "demo-ingress"
        target = k8sTarget.res
        metadata {
            name = appName
            namespace = nsName
        }
        spec {
            rules {
                new {
                    host = ingressHost
                    http {
                        paths {
                            new {
                                path = "/"
                                pathType = "Prefix"
                                backend {
                                    service {
                                        name = appName
                                        port { number = 80 }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
