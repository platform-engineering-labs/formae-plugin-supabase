//
// Full project from scratch — the whole plugin surface in one apply.
//
// Creates a Supabase Project (with nested auth / Data API / Postgres config),
// two API keys, an edge-function secret, and an edge function that reads it.
// Children reference the freshly created project via `project.res.id` — no
// pre-existing project, no second apply.
//
// The initial Postgres password is a formae-managed opaque secret: if you set
// SUPABASE_DB_PASS it's used (still opaque, never logged); otherwise formae
// generates a strong one once and reuses it. Either way no plaintext lands in
// the forma or in state.
//
// Setup:
//   export SUPABASE_ACCESS_TOKEN=sbp_xxx
//   export SUPABASE_ORG_ID=<org slug or id>
//   export SUPABASE_DB_PASS=<postgres password, >= 8 chars>   # optional, formae generates one if unset
//   export OPENAI_API_KEY=sk-...                              # optional, demo fallback otherwise
//   formae apply --mode reconcile --watch examples/full-project/main.pkl
//
// Project create is async (~2 min to ACTIVE_HEALTHY); --watch shows progress.
// Free tier allows 2 projects per org. Tear down with:
//   formae destroy examples/full-project/main.pkl

amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@formae/ext/random.pkl"
import "@supabase/supabase.pkl"

local orgId      = read("env:SUPABASE_ORG_ID")
local openaiKey  = read?("env:OPENAI_API_KEY") ?? "sk-demo-not-a-real-key"
local userDbPass = read?("env:SUPABASE_DB_PASS")

forma {
  new formae.Stack {
    label = "supabase-full-project"
    description = "Complete Supabase product stack from a single apply"
  }

  new formae.Target {
    label = "supabase-target"
    config = new supabase.Config {}
  }

  // The project itself. Nested blocks PATCH the project's auth, Data API
  // (PostgREST), and Postgres settings right after creation.
  local project = new supabase.Project {
    label = "demo-project"
    name = "formae-full-demo"
    organizationId = orgId
    region = "us-east-1"
    // Opaque (never displayed) either way. Use the env value if set, else let
    // formae generate one once (.setOnce) and reuse it on later applies.
    dbPass = if (userDbPass != null) formae.value(userDbPass).opaque
             else formae.value(random.password(16, false)).opaque.setOnce
    plan = "free"
    auth = new supabase.ProjectAuthConfig {
      settings = new Mapping {
        ["site_url"] = "https://example.com"
      }
    }
    api = new supabase.ProjectAPIConfig {
      settings = new Mapping {
        ["max_rows"] = 1000
      }
    }
    database = new supabase.ProjectDatabaseConfig {
      settings = new Mapping {
        ["statement_timeout"] = "10s"
      }
    }
  }
  project

  // Browser-safe key for the web app.
  new supabase.APIKey {
    label = "publishable-key"
    projectRef = project.res.id
    apikey_type = "publishable"
    name = "frontend_publishable"
    description = "Browser-safe key for the web app"
  }

  // Server-side key for trusted services.
  new supabase.APIKey {
    label = "secret-key"
    projectRef = project.res.id
    apikey_type = "secret"
    name = "backend_secret"
    description = "Server-side key for trusted services"
  }

  // Edge-function secrets bag (one resource per project). Values are
  // write-only: the API never returns them, so formae cannot detect drift on
  // the values themselves.
  new supabase.Secrets {
    label = "edge-secrets"
    projectRef = project.res.id
    values {
      ["OPENAI_API_KEY"] = openaiKey
    }
  }

  // Edge function that proves the secret is wired through.
  new supabase.EdgeFunction {
    label = "ask-ai"
    projectRef = project.res.id
    slug = "ask-ai"
    name = "Ask AI"
    verify_jwt = true
    body = """
      Deno.serve(() => {
        const key = Deno.env.get("OPENAI_API_KEY") ?? "unset"
        return new Response(
          JSON.stringify({ openaiKeyPrefix: key.slice(0, 7) }),
          { headers: { "Content-Type": "application/json" } },
        )
      })
      """
  }
}
