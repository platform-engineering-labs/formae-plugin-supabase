//
// Basic example — manage one Supabase Edge Function on an existing project.
//
// Setup:
//   export SUPABASE_ACCESS_TOKEN=sbp_xxx
//   export SUPABASE_PROJECT_REF=<existing project ref>
//   formae apply --mode reconcile --watch examples/basic/main.pkl

amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@supabase/supabase.pkl"

local projectRef = read("env:SUPABASE_PROJECT_REF")

forma {
  new formae.Stack {
    label = "supabase-demo"
    description = "Basic Supabase plugin example"
  }

  new formae.Target {
    label = "supabase-target"
    config = new supabase.Config {}
  }

  // One Edge Function deployed from inline source.
  new supabase.EdgeFunction {
    label = "hello-world"
    projectRef = projectRef
    slug = "hello-world"
    name = "Hello World"
    body = """
      Deno.serve(() => new Response("Hello from formae!"))
      """
    verify_jwt = true
  }
}
