// Minimal demo forma — just the bare Supabase target.
//
// project.pkl in this directory is the full extracted state: one Project with
// its per-project config (auth / api / database / network) nested inside it,
// plus API keys, an edge function, and a secret.
//
// For the live "change one thing" beat, edit project.pkl — e.g. flip
// Project.api.settings.max_rows from 1000 to 5000 — and re-apply. Nested
// config is applied as a PATCH/PUT against the existing project, so the
// change lands in ~2 seconds.

amends "@formae/forma.pkl"
import "@formae/formae.pkl"
import "@supabase/supabase.pkl" as supabase

forma {
    new formae.Target {
        label = "supabase-target"
        config = new supabase.Config {}
    }
}
