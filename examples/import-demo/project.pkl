amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@supabase/supabase.pkl" as supabase

forma {

  local myStack = new formae.Stack {
    label = "imported-supabase-project"
    description = "Adopted from existing Supabase project via formae extract"
  }
  myStack

  local k8sSupabaseDemo = new formae.Stack {
    label = "k8s-supabase-demo"
    description = "Cross-plugin demo: k8s app reading Supabase credentials"
  }
  k8sSupabaseDemo


  local supabaseTarget = new formae.Target {
    label = "supabase-target"
    namespace = "SUPABASE"
    discoverable = true
    config {
      organizationId = "REDACTED_ORG_ID"
      Type = "SUPABASE"
      OrganizationId = "REDACTED_ORG_ID"
    }
  }
  supabaseTarget

  new supabase.APIKey {
    label = "default-1"
    projectRef = "REDACTED_PROJECT_REF"
    apikey_type = "publishable"
    name = "default"
    target = supabaseTarget.res
    stack = myStack.res
  }

  new supabase.APIKey {
    label = "default-2"
    projectRef = "REDACTED_PROJECT_REF"
    apikey_type = "secret"
    name = "default"
    target = supabaseTarget.res
    stack = myStack.res
  }

  new supabase.APIKey {
    label = "demo-publishable"
    projectRef = "REDACTED_PROJECT_REF"
    apikey_type = "publishable"
    name = "k8s_demo_publishable"
    description = "k8s_supabase_demo"
    target = supabaseTarget.res
    stack = k8sSupabaseDemo.res
  }

  new supabase.APISettings {
    label = "REDACTED_PROJECT_REF"
    projectRef = "REDACTED_PROJECT_REF"
    settings = new Mapping {
      ["db_extra_search_path"] = "public, extensions"
      ["db_schema"] = "public,graphql_public"
      ["max_rows"] = 1000
      // jwt_secret is omitted on purpose. Rewriting it would rotate
      // every existing JWT — only set it via formae if you also intend
      // to roll keys. Export SUPABASE_JWT_SECRET and uncomment to opt in.
      // ["jwt_secret"] = read("env:SUPABASE_JWT_SECRET")
    }
    target = supabaseTarget.res
    stack = myStack.res
  }

  new supabase.AuthSettings {
    label = "demo-auth-settings"
    projectRef = "REDACTED_PROJECT_REF"
    settings = new Mapping {
      ["api_max_request_duration"] = 10
