amends "@formae/forma.pkl"
import "@formae/formae.pkl"

// Resource imports
import "@supabase/supabase.pkl" as supabase

// Redacted output of `formae extract --query 'target:supabase-target'`.
//
// One Supabase project adopted from an existing account. Per-project config
// (auth / api / database / network restrictions) nests INSIDE the Project
// resource — the current model — rather than living as standalone resources.
// Real identifiers are replaced with REDACTED_* placeholders.
//
// Note what extract omits: write-only / non-readable fields the API never
// returns — Project.dbPass, EdgeFunction.body, Secret.value.

forma {

  local myStack = new formae.Stack {
    label = "imported-supabase-project"
    description = "Adopted from an existing Supabase project via formae extract"
  }
  myStack

  local supabaseTarget = new formae.Target {
    label = "supabase-target"
    namespace = "SUPABASE"
    discoverable = true
    config {
      Type = "SUPABASE"
    }
  }
  supabaseTarget

  // The project, with all per-project config nested. dbPass is absent —
  // it's write-only, so extract can't read it back.
  new supabase.Project {
    label = "REDACTED_PROJECT_REF"
    name = "my-project"
    organizationId = "REDACTED_ORG_ID"
    region = "us-east-1"
    plan = "free"
    target = supabaseTarget.res
    stack = myStack.res

    // PostgREST (Data API) config → PATCH /v1/projects/{ref}/postgrest
    api = new supabase.ProjectAPIConfig {
      settings = new Mapping {
        ["db_schema"] = "public,graphql_public"
        ["db_extra_search_path"] = "public, extensions"
        ["max_rows"] = 1000
      }
    }

    // Auth config → PATCH /v1/projects/{ref}/config/auth. jwt_secret is
    // omitted on purpose — rewriting it rotates every existing JWT.
    auth = new supabase.ProjectAuthConfig {
      settings = new Mapping {
        ["site_url"] = "http://localhost:3000"
        ["disable_signup"] = false
        ["jwt_exp"] = 3600
        ["mailer_autoconfirm"] = false
      }
    }

    // Postgres tuning → PUT /v1/projects/{ref}/config/database/postgres
    database = new supabase.ProjectDatabaseConfig {
      settings = new Mapping {
        ["max_connections"] = 60
        ["statement_timeout"] = "8s"
      }
    }

    // CIDR allow-list → PATCH /v1/projects/{ref}/network-restrictions
    networkRestriction = new supabase.ProjectNetworkRestriction {
      settings = new Mapping {
        ["dbAllowedCidrs"] = new Listing { "0.0.0.0/0" }
        ["dbAllowedCidrsV6"] = new Listing { "::/0" }
      }
    }
  }

  new supabase.APIKey {
    label = "default-publishable"
    projectRef = "REDACTED_PROJECT_REF"
    apikey_type = "publishable"
    name = "default"
    target = supabaseTarget.res
    stack = myStack.res
  }

  new supabase.APIKey {
    label = "default-secret"
    projectRef = "REDACTED_PROJECT_REF"
    apikey_type = "secret"
    name = "default"
    target = supabaseTarget.res
    stack = myStack.res
  }

  // body is absent — the API doesn't return Edge Function source on read.
  new supabase.EdgeFunction {
    label = "hello-world"
    projectRef = "REDACTED_PROJECT_REF"
    slug = "hello-world"
    name = "Hello World"
    target = supabaseTarget.res
    stack = myStack.res
  }

  // value is absent — secrets are write-only.
  new supabase.Secret {
    label = "MY_SECRET"
    projectRef = "REDACTED_PROJECT_REF"
    name = "MY_SECRET"
    target = supabaseTarget.res
    stack = myStack.res
  }
}
