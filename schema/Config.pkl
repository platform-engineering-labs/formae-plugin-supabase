/// Plugin configuration.
/// Customize this with plugin-specific settings that users can set in formae.conf.pkl.
///
/// Users import this via: import "plugins:/Supabase.pkl" as Supabase
///
/// Then use it in their formae.conf.pkl:
///   agent {
///       resourcePlugins {
///           new Supabase.PluginConfig {
///               rateLimit { maxRequestsPerSecond = 5 }
///           }
///       }
///   }
open module supabase.Config

extends "formae:/Config.pkl"

class PluginConfig extends BaseResourcePluginConfig {
    type = "supabase"
}
