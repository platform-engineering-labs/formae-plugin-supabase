amends "pkl:Project"

// Package configuration. `version` is read from the sibling VERSION file so
// the Hub build pipeline can stamp the release version (it writes VERSION
// before `pkl project package`); hardcoding it makes the packaged artifact
// version diverge from the pipeline's expected path. Matches sibling plugins.
package {
  name = "supabase"
  baseUri = "package://hub.platform.engineering/plugins/supabase/schema/pkl/\(name)"
  version = read("VERSION").text.trim()
  packageZipUrl = "https://hub.platform.engineering/plugins/supabase/schema/pkl/\(name)/\(name)@\(version).zip"
}

dependencies {
  ["formae"] {
    uri = "package://hub.platform.engineering/plugins/pkl/schema/pkl/formae/formae@0.84.0"
  }
}
