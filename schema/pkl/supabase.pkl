/// Supabase Management API resource definitions.
///
/// Only resources implemented in the plugin appear here.
module supabase

import "@formae/formae.pkl"

// =============================================================================
// Target configuration
// =============================================================================

/// Deployment-level config for a Supabase target.
///
/// Credentials live in environment variables (SUPABASE_ACCESS_TOKEN), never
/// in the forma — same pattern as formae-plugin-sftp.
open class Config {
    hidden fixed type: String = "SUPABASE"

    /// Override base URL. Defaults to https://api.supabase.com.
    baseUrl: String? = null

    /// Advanced / conformance-only. Scopes sub-resource `List()` and
    /// discovery (Branch, APIKey, EdgeFunction, Secret) to a single
    /// Supabase project. Leave unset in normal use — discovery then walks
    /// every project the PAT can see. The conformance suite sets it to
    /// keep sub-resource discovery within the harness's 2-minute window;
    /// production targets should omit it. Project discovery is always
    /// global regardless of this field.
    projectRef: String? = null

    fixed Type: String = type
    fixed BaseUrl: String? = baseUrl
    fixed ProjectRef: String? = projectRef
}

// =============================================================================
// SUPABASE::Platform::Project
// =============================================================================

/// A Supabase project. Maps to POST /v1/projects.
///
/// Project create is async; the plugin waits for ACTIVE_HEALTHY via Status().
@formae.ResourceHint {
    type = "SUPABASE::Platform::Project"
    identifier = "$.id"
    discoverable = true
}
class Project extends formae.Resource {
    fixed hidden type: String = "SUPABASE::Platform::Project"

    /// Project display name.
    @formae.FieldHint { requiredOnCreate = true }
    name: String

    /// Organization slug or id that owns the project.
    /// Immutable after creation.
    @formae.FieldHint {
        createOnly = true
        requiredOnCreate = true
    }
    organizationId: String

    /// AWS region (e.g. "us-east-1", "eu-west-1").
    /// Immutable after creation.
    @formae.FieldHint {
        createOnly = true
        requiredOnCreate = true
    }
    region: String

    /// Initial Postgres password. >= 8 chars.
    /// Send-only — never returned by the API. Declared nullable on purpose:
    /// the schema extractor marks every non-nullable, no-default field as
    /// `Required`, and discovery rejects any resource whose `Required` fields
    /// aren't present in the Read response. Since the API never echoes the
    /// password, a non-nullable `dbPass` makes every existing project
    /// undiscoverable. Create() enforces presence in Go instead.
    @formae.FieldHint {
        createOnly = true
        writeOnly = true
    }
    dbPass: String?

    /// Pricing plan ("free", "pro", "team", "enterprise").
    @formae.FieldHint {}
    plan: String? = "free"

    /// Compute instance size (e.g. "micro", "small", "medium").
    @formae.FieldHint {}
    desiredInstanceSize: String? = null

    /// Auth configuration block (PATCHes /v1/projects/{ref}/config/auth
    /// when set). Plugin tracks managed keys so unmanaged cloud fields
    /// don't surface as drift.
    @formae.FieldHint {}
    auth: ProjectAuthConfig? = null

    /// PostgREST (Data API) configuration block. PATCHes
    /// /v1/projects/{ref}/postgrest when set.
    @formae.FieldHint {}
    api: ProjectAPIConfig? = null

    /// Postgres database tuning block. PUTs
    /// /v1/projects/{ref}/config/database/postgres when set.
    @formae.FieldHint {}
    database: ProjectDatabaseConfig? = null

    /// Network CIDR allow-list block. PATCHes
    /// /v1/projects/{ref}/network-restrictions when set.
    @formae.FieldHint {}
    networkRestriction: ProjectNetworkRestriction? = null
}

/// Auth config payload. Settings is opaque JSON matching
/// UpdateAuthConfigBody in the Supabase Management API.
class ProjectAuthConfig {
    settings: Mapping<String, Any>?
}

/// PostgREST config payload. Settings keys: db_schema, db_extra_search_path,
/// max_rows, db_pool, ...
class ProjectAPIConfig {
    settings: Mapping<String, Any>?
}

/// Postgres config payload. Settings keys: max_connections, shared_buffers,
/// work_mem, ...
class ProjectDatabaseConfig {
    settings: Mapping<String, Any>?
}

/// Network restriction payload. Settings shape:
/// { "dbAllowedCidrs": [...], "dbAllowedCidrsV6": [...] }.
class ProjectNetworkRestriction {
    settings: Mapping<String, Any>?
}

// =============================================================================
// SUPABASE::Platform::Branch
// =============================================================================

/// A preview branch on a Supabase project.
/// Async — plugin polls until status reaches FUNCTIONS_DEPLOYED / MIGRATIONS_PASSED.
@formae.ResourceHint {
    type = "SUPABASE::Platform::Branch"
    identifier = "$.id"
    discoverable = true
}
class Branch extends formae.Resource {
    fixed hidden type: String = "SUPABASE::Platform::Branch"

    /// Parent project reference. Immutable after creation.
    @formae.FieldHint {
        createOnly = true
        requiredOnCreate = true
    }
    parentProjectRef: String

    /// Branch name.
    @formae.FieldHint { requiredOnCreate = true }
    branch_name: String

    /// Optional Git branch name to track.
    @formae.FieldHint {}
    git_branch: String?

    /// Whether the branch is persistent.
    @formae.FieldHint {}
    persistent: Boolean? = false

    /// Region for the branch's database. Immutable.
    @formae.FieldHint { createOnly = true }
    region: String?

    /// Compute instance size for the branch.
    @formae.FieldHint { createOnly = true }
    desired_instance_size: String?
}

// =============================================================================
// SUPABASE::Auth::APIKey
// =============================================================================

/// Resolvable handle for `SUPABASE::Auth::APIKey` outputs. Reference
/// these from other resources to wire credentials across plugins, e.g.
///   stringData["NEXT_PUBLIC_SUPABASE_ANON_KEY"] = anonKey.res.apiKey
open class APIKeyResolvable extends formae.Resolvable {
    hidden type = "SUPABASE::Auth::APIKey"

    hidden id:     APIKeyResolvable = (this) { property = "id" }
    hidden apiKey: APIKeyResolvable = (this) { property = "apiKey" }
    hidden prefix: APIKeyResolvable = (this) { property = "prefix" }
}

/// Project-scoped API key (publishable or secret).
@formae.ResourceHint {
    type = "SUPABASE::Auth::APIKey"
    identifier = "$.id"
    discoverable = true
}
class APIKey extends formae.Resource {
    fixed hidden type: String = "SUPABASE::Auth::APIKey"

    local parent = this
    hidden res: APIKeyResolvable = new {
        label = parent.label
        stack = parent.stack?.label
    }

    /// Parent project reference. Immutable.
    @formae.FieldHint {
        createOnly = true
        requiredOnCreate = true
    }
    projectRef: String

    /// "publishable" or "secret". Immutable.
    @formae.FieldHint {
        createOnly = true
        requiredOnCreate = true
    }
    apikey_type: String

    /// Short key name (lowercase, snake_case, 4–64 chars).
    @formae.FieldHint { requiredOnCreate = true }
    name: String

    /// Optional description.
    @formae.FieldHint {}
    description: String?
}

// =============================================================================
// SUPABASE::Functions::EdgeFunction
// =============================================================================

/// A Supabase Edge Function deployed from an inline body.
@formae.ResourceHint {
    type = "SUPABASE::Functions::EdgeFunction"
    identifier = "$.slug"
    discoverable = true
}
class EdgeFunction extends formae.Resource {
    fixed hidden type: String = "SUPABASE::Functions::EdgeFunction"

    /// Parent project. Immutable.
    @formae.FieldHint {
        createOnly = true
        requiredOnCreate = true
    }
    projectRef: String

    /// URL-safe slug. Immutable.
    @formae.FieldHint {
        createOnly = true
        requiredOnCreate = true
    }
    slug: String

    /// Display name.
    @formae.FieldHint { requiredOnCreate = true }
    name: String

    /// Inline TypeScript/JavaScript source body (Deno). Nullable on purpose:
    /// the extractor marks non-nullable, no-default fields as `Required`, and
    /// the API never returns the source on Read, so a non-nullable `body`
    /// makes existing functions undiscoverable. Create() enforces presence.
    @formae.FieldHint {}
    body: String?

    /// Whether to verify the JWT before invocation.
    @formae.FieldHint {}
    verify_jwt: Boolean? = true
}

// =============================================================================
// SUPABASE::Functions::Secret
// =============================================================================

/// One Edge Function secret. Values are write-only.
@formae.ResourceHint {
    type = "SUPABASE::Functions::Secret"
    identifier = "$.name"
    discoverable = true
}
class Secret extends formae.Resource {
    fixed hidden type: String = "SUPABASE::Functions::Secret"

    /// Parent project. Immutable.
    @formae.FieldHint {
        createOnly = true
        requiredOnCreate = true
    }
    projectRef: String

    /// Secret name. Must not start with SUPABASE_. Immutable.
    @formae.FieldHint {
        createOnly = true
        requiredOnCreate = true
    }
    name: String

    /// Secret value. Send-only — never returned by the API. Nullable on
    /// purpose: the extractor marks non-nullable, no-default fields as
    /// `Required`, and discovery rejects resources whose `Required` fields
    /// are absent from Read. A non-nullable `value` makes existing secrets
    /// undiscoverable. Create() enforces presence in Go.
    @formae.FieldHint {
        writeOnly = true
    }
    value: String?
}

